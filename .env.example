NODE_ENV=development
RABBITMQ_URL=amqp://app:app@localhost:5672
QUEUE_RAW_EVENT=source.raw.v1
QUEUE_QUARANTINE_EVENT=source.raw.quarantine.v1
SCRAPE_SCHEDULE=*/20 * * * *
SHARED_CONTRACTS_DIR=../shared-contracts

S3_ENDPOINT=http://localhost:9000
S3_REGION=ru-central-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=artifacts
S3_FORCE_PATH_STYLE=true

ENABLED_SOURCES=demo-source
DEMO_SOURCE_BASE_URL=https://demo-source.local
DEMO_SOURCE_ITEM_COUNT=2

FIND_TENDER_API_URL=https://www.find-tender.service.gov.uk/api/1.0/ocdsReleasePackages?limit=5
REQUEST_TIMEOUT_MS=15000
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_OPEN_MS=600000

# Optional proxy vars for environments where outbound HTTP must go through a proxy
# HTTP_PROXY=http://proxy.local:3128
# HTTPS_PROXY=http://proxy.local:3128
# NO_PROXY=localhost,127.0.0.1
